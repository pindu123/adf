			"type": "string",
			"defaultValue": "/subscriptions/4d829107-c197-4465-8b1b-676ebd2084d8/resourceGroups/abc/providers/Microsoft.Storage/storageAccounts/strgacc670"
		},
		"NewFileArrivalTrigger_properties_PL_MappingDataFlow_parameters_FileName1": {
